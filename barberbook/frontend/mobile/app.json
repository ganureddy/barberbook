{
  "expo": {
    "name": "BarberBook",
    "slug": "barberbook",
    "scheme": "barberbook",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF7F2"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.barberbook.client",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "BarberBook uses your location to show nearby shops and live walk-in queues.",
        "NSCameraUsageDescription": "BarberBook uses the camera so you can attach photos to reviews and KYC documents.",
        "NSPhotoLibraryUsageDescription": "BarberBook uses your photos to upload review images and KYC documents.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "app.barberbook.client",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#D4322C"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "INTERNET",
        "READ_EXTERNAL_STORAGE",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-localization",
      "expo-secure-store",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "BarberBook uses your location to show nearby shops and live queue ETAs."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "BarberBook needs access to your photos so you can attach images to reviews."
        }
      ]
    ],
    "extra": {
      "frappe": {
        "siteUrlEnv": "EXPO_PUBLIC_FRAPPE_URL"
      },
      "eas": {
        "projectId": "748cc12c-e156-46f6-a23a-910128f3e29f"
      }
    },
    "owner": "ganureddylife",
    "updates": {
      "url": "https://u.expo.dev/748cc12c-e156-46f6-a23a-910128f3e29f",
      "fallbackToCacheTimeout": 0
    }
  }
}
