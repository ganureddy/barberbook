{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "node": "20.18.0",
      "env": {
        "EXPO_PUBLIC_DEFAULT_COUNTRY": "IN"
      }
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "channel": "dev",
      "ios": {
        "simulator": true,
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      },
      "env": {
        "EXPO_PUBLIC_CHANNEL": "dev",
        "EXPO_PUBLIC_MOCK": "1",
        "EXPO_PUBLIC_FRAPPE_URL": "https://staging.barberbook.app",
        "EXPO_PUBLIC_SENTRY_DSN": ""
      }
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "channel": "preview",
      "ios": {
        "simulator": false,
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_CHANNEL": "preview",
        "EXPO_PUBLIC_MOCK": "0",
        "EXPO_PUBLIC_FRAPPE_URL": "https://staging.barberbook.app",
        "EXPO_PUBLIC_SENTRY_DSN": "$EXPO_PUBLIC_SENTRY_DSN_STAGING"
      }
    },
    "production": {
      "extends": "base",
      "channel": "production",
      "autoIncrement": true,
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_CHANNEL": "production",
        "EXPO_PUBLIC_MOCK": "0",
        "EXPO_PUBLIC_FRAPPE_URL": "https://app.barberbook.app",
        "EXPO_PUBLIC_SENTRY_DSN": "$EXPO_PUBLIC_SENTRY_DSN_PROD"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "$ASC_APP_ID",
        "appleTeamId": "$APPLE_TEAM_ID"
      },
      "android": {
        "track": "production",
        "releaseStatus": "draft",
        "serviceAccountKeyPath": "./google-play-service-account.json"
      }
    }
  }
}
