{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "node": "22.13.0",
      "env": {
        "EXPO_PUBLIC_DEFAULT_COUNTRY": "IN"
      }
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "channel": "dev",
      "ios": {
        "simulator": true,
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      },
      "env": {
        "EXPO_PUBLIC_CHANNEL": "dev",
        "EXPO_PUBLIC_MOCK": "1",
        "EXPO_PUBLIC_FRAPPE_URL": "http://184.168.124.163"
      }
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "channel": "preview",
      "ios": {
        "simulator": false,
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_CHANNEL": "preview",
        "EXPO_PUBLIC_MOCK": "1",
        "EXPO_PUBLIC_FRAPPE_URL": "http://184.168.124.163"
      }
    },
    "android-lifescc": {
      "extends": "base",
      "distribution": "internal",
      "channel": "lifescc",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_CHANNEL": "lifescc",
        "EXPO_PUBLIC_MOCK": "1",
        "EXPO_PUBLIC_FRAPPE_URL": "http://184.168.124.163"
      }
    },
    "production": {
      "extends": "base",
      "channel": "production",
      "autoIncrement": true,
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_CHANNEL": "production",
        "EXPO_PUBLIC_MOCK": "0",
        "EXPO_PUBLIC_FRAPPE_URL": "http://184.168.124.163"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "production",
        "releaseStatus": "draft",
        "serviceAccountKeyPath": "./google-play-service-account.json"
      }
    }
  }
}
