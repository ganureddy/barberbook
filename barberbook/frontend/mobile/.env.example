# BarberBook mobile env. Copy to `.env.local` and edit for your dev box.
# All EXPO_PUBLIC_* vars are inlined into the JS bundle at build time —
# do NOT put secrets here. Anything sensitive belongs on Frappe.

# ────────────────────────────────────────────────────────────────────
# Frappe site
# ────────────────────────────────────────────────────────────────────
# Base URL of your Frappe site. NO trailing slash.
# - iOS Simulator on the same machine as bench: http://localhost:8000
# - Android Emulator (AOSP):                   http://10.0.2.2:8000
# - Physical device on Wi-Fi:                  http://<your-LAN-ip>:8000
# - Staging:                                   https://staging.barberbook.app
# - Production:                                https://ride.emrid.store
EXPO_PUBLIC_FRAPPE_URL=https://ride.emrid.store

# 1 = short-circuit every API call to in-process mock fixtures (no network).
# 0 = hit the real Frappe site at EXPO_PUBLIC_FRAPPE_URL.
# Default in dev is 1 so the app boots before the backend exists.
EXPO_PUBLIC_MOCK=1

# Default country for discovery / currency formatting. IN | AE | GB.
EXPO_PUBLIC_DEFAULT_COUNTRY=IN

# Surfaces in DevHud + crash reports.
EXPO_PUBLIC_CHANNEL=dev
EXPO_PUBLIC_APP_VERSION=1.0.0

# ────────────────────────────────────────────────────────────────────
# Optional: feature flags
# ────────────────────────────────────────────────────────────────────
# Force a specific locale at boot regardless of device locale.
# Useful for QA passes. en | hi | ar.
# EXPO_PUBLIC_FORCE_LOCALE=ar

# Force a density preference (overrides user setting).
# comfortable | compact.
# EXPO_PUBLIC_FORCE_DENSITY=compact

# ────────────────────────────────────────────────────────────────────
# Optional: error reporting
# ────────────────────────────────────────────────────────────────────
# Sentry DSN (per-channel). Leave empty in dev to silence Sentry init.
# Production builds via EAS receive the DSN via eas.json + GH secrets,
# so this only affects local builds.
EXPO_PUBLIC_SENTRY_DSN=

# ────────────────────────────────────────────────────────────────────
# Optional: maps / push
# ────────────────────────────────────────────────────────────────────
# Google Maps API key for Android. iOS uses Apple Maps by default.
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Expo push endpoint override (defaults to https://exp.host/--/api/v2/push/send).
# EXPO_PUBLIC_EXPO_PUSH_URL=

# ────────────────────────────────────────────────────────────────────
# Optional: OTP fixed code (dev only)
# ────────────────────────────────────────────────────────────────────
# When the Frappe site_config has `barberbook_dev_otp: 1`, the verify
# endpoint accepts `424242`. The mobile DevHud surfaces this for QA.
# EXPO_PUBLIC_DEV_OTP=424242
