# BarberBook mobile env. Copy to `.env.local` and edit for your dev box.
# All EXPO_PUBLIC_* vars are inlined into the JS bundle at build time —
# do NOT put secrets here. Anything sensitive belongs on Frappe.

# Base URL of your Frappe site. NO trailing slash.
# - iOS Simulator on the same machine as bench: http://localhost:8000
# - Android Emulator (AOSP): http://10.0.2.2:8000
# - Physical device on Wi-Fi: http://<your-LAN-ip>:8000
EXPO_PUBLIC_FRAPPE_URL=http://localhost:8000

# 1 = short-circuit every API call to in-process mock fixtures (no network).
# 0 = hit the real Frappe site at EXPO_PUBLIC_FRAPPE_URL.
# Default in dev is 1 so the app boots before the backend exists.
EXPO_PUBLIC_MOCK=1

# Default country for discovery / currency formatting. IN | AE | GB.
EXPO_PUBLIC_DEFAULT_COUNTRY=IN

# Surfaces in DevHud + crash reports.
EXPO_PUBLIC_CHANNEL=dev
EXPO_PUBLIC_APP_VERSION=0.1.0
